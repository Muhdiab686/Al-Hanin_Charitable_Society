        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}",
                  "if (json.beneficiary_id) {",
                  "  pm.collectionVariables.set('beneficiary_id', json.beneficiary_id);",
                  "}"
                ]
              }
            }
